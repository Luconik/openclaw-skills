# ── Classic Central (monitoring) ─────────────────────────────────────────────
# Account Home → API Gateway → My Apps & Tokens
CENTRAL_CLASSIC_BASE=https://apigw-<your-cluster>.central.arubanetworks.com
CENTRAL_CLIENT_ID=YOUR_CLIENT_ID
CENTRAL_CLIENT_SECRET=YOUR_CLIENT_SECRET
CENTRAL_CLASSIC_TOKEN=YOUR_ACCESS_TOKEN
CENTRAL_CLASSIC_REFRESH=YOUR_REFRESH_TOKEN

# ── New Central / GreenLake (config) ─────────────────────────────────────────
# GreenLake → Manage Workspace → Personal API clients
# Service: HPE Aruba Networking Central
CENTRAL_BASE_URL=https://<your-cluster>.api.central.arubanetworks.com
CENTRAL_GL_CLIENT_ID=YOUR_GL_CLIENT_ID
CENTRAL_GL_CLIENT_SECRET=YOUR_GL_CLIENT_SECRET

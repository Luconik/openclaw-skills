# Proxmox API Token format: USER@REALM!TOKENID=UUID
# Create in Proxmox UI: Datacenter → Permissions → API Tokens

# Global fallback
PVE_HOST=192.168.1.10
PVE_TOKEN=root@pam!openclaw=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Node-specific (override global)
PVE1_HOST=192.168.1.10
PVE1_TOKEN=root@pam!openclaw=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

PVE2_HOST=192.168.1.11
PVE2_TOKEN=root@pam!openclaw=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx